LCCFWSP_LOG_LEVEL=info

LCCFWSP_API_DISABLE_DOCS=false

LCCFWSP_DB_PATH=./data/db.sqlite
LCCFWSP_DB_AUTO_MIGRATE=true

LCCFWSP_CONFIG_BASE_DIR=./config

LCCFWSP_APP_URL=http://localhost:12336

